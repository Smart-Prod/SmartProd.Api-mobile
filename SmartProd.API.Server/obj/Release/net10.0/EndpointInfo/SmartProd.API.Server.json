            "type": [
              "null",
              "string"
            ]
          },
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "senha": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TipoProduto": {
        "type": "integer"
      },
