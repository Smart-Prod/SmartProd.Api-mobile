      },
      "NotaFiscalCreateDto": {
        "required": [
          "type",
          "number",
          "date",
          "items"
        ],
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/NotaFiscalTipo"
          },
          "number": {
            "type": [
              "null",
              "string"
            ]
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "supplier": {
            "type": [
              "null",
              "string"
            ]
          },
          "customer": {
            "type": [
              "null",
              "string"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotaFiscalItemCreateDto"
            }
          }
        }
      },
      "NotaFiscalItemCreateDto": {
        "required": [
          "productId",
          "quantity",
          "value"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "value": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "NotaFiscalTipo": {
        "type": "integer"
      },
      "OrdemProducaoCreateDto": {
        "type": "object",
        "properties": {
