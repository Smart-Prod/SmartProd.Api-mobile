          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tipo": {
            "$ref": "#/components/schemas/TipoProduto"
          },
          "unit": {
            "type": "string"
          },
          "estoqueAtual": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "estoqueReservado": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "estoqueMínimo": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "RegisterDto": {
        "type": "object",
